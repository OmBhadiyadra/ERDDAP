# Set DB_MODE=local to use SQLite (default)
# Set DB_MODE=prod to use real MySQL RDS
DB_MODE=local

# Set STORAGE_MODE=local to save to output/ folder (default)
# Set STORAGE_MODE=prod to upload to real AWS S3
STORAGE_MODE=local

# AWS credentials (only needed if STORAGE_MODE=prod)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=cumulus-wave-data

# Application settings
DEBUG_MODE=false
MAX_RETRIES=3
RETRY_DELAY=2
REQUEST_TIMEOUT=30
